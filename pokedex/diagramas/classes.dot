digraph Classes {
    rankdir=TB;
    fontname="Arial";
    labelloc="t";
    label="Diagrama de Classes - Modelo e Persistência - Sistema de Gerenciamento Pokémon (Dupla - 6 entidades)";
    fontsize=15;
    bgcolor="white";
    nodesep=0.55;
    ranksep=0.65;

    node [shape=record, fontname="Arial", fontsize=10, style="filled", fillcolor="white", color="black", penwidth=1.0];
    edge [fontname="Arial", fontsize=9, color="black", penwidth=1.0];

    Usuario [label="{Usuario|+ id : int\l+ nome : String\l+ email : String\l+ senha : String\l+ perfil : String\l|+ Usuario(nome, email, senha, perfil)\l+ to_dict() : dict\l+ from_dict(dict) : Usuario\l}"];

    Tipo [label="{Tipo|+ id : int\l+ nome : String\l+ descricao : String\l|+ Tipo(nome, descricao)\l+ to_dict() : dict\l+ from_dict(dict) : Tipo\l}"];

    Habitat [label="{Habitat|+ id : int\l+ nome : String\l+ descricao : String\l|+ Habitat(nome, descricao)\l+ to_dict() : dict\l+ from_dict(dict) : Habitat\l}"];

    Regiao [label="{Regiao|+ id : int\l+ nome : String\l+ descricao : String\l|+ Regiao(nome, descricao)\l+ to_dict() : dict\l+ from_dict(dict) : Regiao\l}"];

    Pokemon [label="{Pokemon|+ id : int\l+ nome : String\l+ numeroPokedex : int\l+ tipoId : int\l+ habitatId : int\l+ regiaoId : int\l+ hpBase : int\l+ qtdAvistados : int\l+ qtdDisponivel : int\l|+ Pokemon(nome, numeroPokedex, tipoId,\l  habitatId, regiaoId, hpBase, qtdAvistados)\l+ to_dict() : dict\l+ from_dict(dict) : Pokemon\l}"];

    Captura [label="{Captura|+ id : int\l+ pokemonId : int\l+ treinadorId : int\l+ apelido : String\l+ dataCaptura : String\l+ dataLibertacao : String\l+ status : String\l|+ Captura(pokemonId, treinadorId,\l  apelido, dataCaptura)\l+ to_dict() : dict\l+ from_dict(dict) : Captura\l}"];

    // ---- Associações de modelo (1..N), com multiplicidade em cada ponta ----
    Tipo -> Pokemon [dir=none, arrowtail=none, taillabel="1", headlabel="0..*", label="classifica", labeldistance=2.2];
    Habitat -> Pokemon [dir=none, taillabel="1", headlabel="0..*", label="abriga", labeldistance=2.2];
    Regiao -> Pokemon [dir=none, taillabel="1", headlabel="0..*", label="origina", labeldistance=2.2];
    Pokemon -> Captura [dir=none, taillabel="1", headlabel="0..*", label="é alvo de", labeldistance=2.2];
    Usuario -> Captura [dir=none, taillabel="1", headlabel="0..*", label="realiza", labeldistance=2.2];

    subgraph cluster_persistencia {
        label="Camada de Persistência (JSON)";
        fontname="Arial";
        fontsize=11;
        style="dashed";
        color="black";
        labeljust="l";

        node [shape=record, fontname="Arial", fontsize=9, style="filled", fillcolor="white"];

        RepositorioBase [label="{«abstract»\nRepositorioBase|+ arquivo : String\l|+ salvarTodos(lista : List) : void\l+ carregarTodos() : List\l+ proximoId() : int\l}"];

        UsuarioRepositorio [label="{UsuarioRepositorio|+ arquivo = \"usuarios.json\"\l|+ inserir/listar/buscarPorId\l+ atualizar/excluir\l+ pesquisarPorNome(termo) : List\l}"];
        TipoRepositorio [label="{TipoRepositorio|+ arquivo = \"tipos.json\"\l|+ inserir/listar/buscarPorId\l+ atualizar/excluir\l+ pesquisarPorNome(termo) : List\l}"];
        HabitatRepositorio [label="{HabitatRepositorio|+ arquivo = \"habitats.json\"\l|+ inserir/listar/buscarPorId\l+ atualizar/excluir\l+ pesquisarPorNome(termo) : List\l}"];
        RegiaoRepositorio [label="{RegiaoRepositorio|+ arquivo = \"regioes.json\"\l|+ inserir/listar/buscarPorId\l+ atualizar/excluir\l+ pesquisarPorNome(termo) : List\l}"];
        PokemonRepositorio [label="{PokemonRepositorio|+ arquivo = \"pokemons.json\"\l|+ inserir/listar/buscarPorId\l+ atualizar/excluir\l+ pesquisarPorNome(termo) : List\l}"];
        CapturaRepositorio [label="{CapturaRepositorio|+ arquivo = \"capturas.json\"\l|+ inserir/listar/buscarPorId\l+ atualizar/excluir\l+ listarPorTreinador(id) : List\l}"];

        edge [style="solid", dir=back, arrowtail=empty, label="", fontsize=9];
        RepositorioBase -> UsuarioRepositorio;
        RepositorioBase -> TipoRepositorio;
        RepositorioBase -> HabitatRepositorio;
        RepositorioBase -> RegiaoRepositorio;
        RepositorioBase -> PokemonRepositorio;
        RepositorioBase -> CapturaRepositorio;
    }

    edge [style="dashed", dir=forward, arrowhead=open, penwidth=1.0, label="", taillabel="", headlabel=""];
    UsuarioRepositorio -> Usuario [label="«persiste»"];
    TipoRepositorio -> Tipo [label="«persiste»"];
    HabitatRepositorio -> Habitat [label="«persiste»"];
    RegiaoRepositorio -> Regiao [label="«persiste»"];
    PokemonRepositorio -> Pokemon [label="«persiste»"];
    CapturaRepositorio -> Captura [label="«persiste»"];
}
